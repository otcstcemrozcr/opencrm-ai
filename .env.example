# --- Database (local-first) ---
# Local Postgres example:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/opencrm
# Neon example (pooled):
#   DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# --- Auth ---
# Generate a strong secret, e.g. (PowerShell):
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_SECRET=

# --- Email (Resend) — needed for invitations & password reset (Sprint 1) ---
RESEND_API_KEY=

# --- AI (Anthropic) — needed for AI Insight v1 (Sprint 3) ---
ANTHROPIC_API_KEY=
