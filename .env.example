# --- Database (local-first) ---
# Local Postgres example:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/opencrm
# Neon example (pooled):
#   DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# --- Auth ---
# Generate a strong secret, e.g. (PowerShell):
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_SECRET=

# --- Email (Resend) — invitations, password reset & overdue digest (Sprint 9B) ---
# Without RESEND_API_KEY the app still works: invite links are shown in the UI
# and reset/digest emails are simply skipped.
RESEND_API_KEY=
# From address for outgoing email (defaults to Resend's onboarding sender).
EMAIL_FROM="OpenCRM AI <onboarding@resend.dev>"

# --- App URL — used to build invite / password-reset links ---
# Falls back to the request host if unset. Set in production, e.g.:
#   NEXT_PUBLIC_APP_URL=https://opencrm-ai.vercel.app
NEXT_PUBLIC_APP_URL=

# --- Notifications (Sprint 9B) ---
# Daily overdue-task digest is posted to a Telegram channel when configured.
# The same bot also powers the two-way Communication Hub (Sprint 11).
TELEGRAM_BOT_TOKEN=
# Secret for the inbound webhook (/api/telegram/webhook). Pass the same value as
# secret_token when calling the Bot API setWebhook.
TELEGRAM_WEBHOOK_SECRET=
# Bot username (without @) — used to build t.me connect deep links.
TELEGRAM_BOT_USERNAME=
# Secret guarding /api/cron/notifications. Vercel Cron sends it automatically
# as `Authorization: Bearer <CRON_SECRET>` when set in project env vars.
CRON_SECRET=

# --- AI (Anthropic) — AI Insight, lead explanation, assistant, drafts ---
ANTHROPIC_API_KEY=

# --- Apollo.io — lead/contact enrichment (Sprint 11) ---
# Without it, the "Enrich with Apollo" buttons report that the key is needed.
APOLLO_API_KEY=
